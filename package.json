{
  "name": "my-app",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "build": "npm run cf-typegen && tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply y-gem-db --remote",
    "local-server": "cd local-server && tsx index.ts"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "@hono/oauth-providers": "^0.8.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "axios": "^1.15.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "express": "^5.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.1"
  }
}
